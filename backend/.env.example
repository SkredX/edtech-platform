# Copy this file to .env and fill in real values. Never commit the real .env.

GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxxxxxx
PINECONE_INDEX=edtech-rag
REDIS_URL=redis://localhost:6379

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
GROQ_CHAT_MODEL=llama-3.1-8b-instant
GROQ_CLONE_MODEL=llama-3.3-70b-versatile
GROQ_INGEST_MODEL=llama-3.1-8b-instant

CACHE_SIMILARITY_THRESHOLD=0.92
CHAT_CONFIDENCE_THRESHOLD=0.70

# Comma-separated list of valid tenant API keys -> tenant_id mapping, e.g.
# key1:tenant-a,key2:tenant-b
TENANT_API_KEYS=devkey123:demo-tenant
